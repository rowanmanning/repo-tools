{
  "name": "@rowanmanning/node-versions",
  "version": "3.1.21",
  "description": "Get the Node.js versions that a repo says it supports",
  "keywords": [],
  "author": "Rowan Manning (https://rowanmanning.com/)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rowanmanning/repo-tools.git",
    "directory": "packages/node-versions"
  },
  "homepage": "https://github.com/rowanmanning/repo-tools/tree/main/packages/node-versions#readme",
  "bugs": "https://github.com/rowanmanning/repo-tools/issues",
  "license": "MIT",
  "engines": {
    "node": "22.x || 24.x"
  },
  "scripts": {
    "fetch-versions": "node ./scripts/fetch-node-versions.js",
    "postinstall": "node ./scripts/fetch-node-versions.js || true",
    "test": "npm run test:unit && npm run test:end-to-end",
    "test:unit": "node --test --experimental-test-module-mocks --experimental-test-coverage --test-coverage-exclude '**/*.test.js' --test-coverage-branches=100 --test-coverage-functions=100 --test-coverage-lines=100 'test/unit/**/*.test.js'",
    "test:end-to-end": "node --test 'test/end-to-end/**/*.test.js'"
  },
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.js"
    }
  },
  "dependencies": {
    "@rowanmanning/package-json": "^2.1.0",
    "semver": "^7.7.4"
  }
}
